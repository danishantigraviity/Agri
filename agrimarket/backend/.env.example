# Server
PORT=5051
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/agrimarket

# AI/ML Microservice
ML_SERVICE_URL=http://127.0.0.1:8000/predict

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Cookie Secret
COOKIE_SECRET=your_cookie_secret_min_32_chars

# Admin Registration Key (keep secret!)
ADMIN_REGISTER_KEY=your_admin_secret_key
